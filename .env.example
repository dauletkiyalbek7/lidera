# Публичные значения Supabase — уходят в браузер, это нормально:
# доступ к данным всё равно ограничен политиками RLS.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Сервисный ключ — ТОЛЬКО на сервере. Обходит RLS.
# Нужен для административных операций (создание аккаунтов сотрудников, Этап 5).
# Никогда не добавлять к нему префикс NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Ключ шифрования секретов интеграций (AES-256-GCM, 32 байта в base64).
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Никогда не добавлять к нему префикс NEXT_PUBLIC_.
LIDERA_SECRETS_KEY=
